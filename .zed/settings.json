{
	"always_treat_brackets_as_autoclosed": true,
	"auto_indent": "syntax_aware",
	"code_actions_on_format": {
		"source.fixAll": true,
		"source.organizeImports": true
	},
	"colorize_brackets": true,
	"disable_ai": false,
	"edit_predictions": {
		"codestral": {},
		"copilot": { "enable_next_edit_suggestions": true },
		"mode": "eager"
	},
	"ensure_final_newline_on_save": true,
	"file_types": {
		"JSONC": [
			"tsconfig.json",
			"jsconfig.json",
			".vscode/*.json",
			".oxfmtrc.json",
			".oxlintrc.json",
			"*.code-workspace",
			"tsconfig*.json",
			"*.code-snippets"
		],
		"Shell Script": ["zsh", "zshrc", "zprofile", "zshenv", "bashrc", "bash_profile"],
		"TOML": ["toml"],
		"YAML": ["*.yml", "*.yaml", ".github/workflows/*.yml", ".github/workflows/*.yaml"]
	},
	"format_on_save": "on",
	"hard_tabs": true,
	"indent_guides": {
		"active_line_width": 1,
		"background_coloring": "disabled",
		"coloring": "indent_aware",
		"enabled": true,
		"line_width": 1
	},
	"inlay_hints": {
		"edit_debounce_ms": 700,
		"enabled": true,
		"scroll_debounce_ms": 50,
		"show_other_hints": true,
		"show_parameter_hints": true,
		"show_type_hints": true
	},
	"jsx_tag_auto_close": { "enabled": true },
	"languages": {
		"CSS": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": false
			},
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "biome" } }, { "language_server": { "name": "oxfmt" } }],
			"hard_tabs": true,
			"language_servers": ["!eslint", "biome", "oxfmt", "..."],
			"prettier": { "allowed": false },
			"tab_size": 4
		},
		"GraphQL": {
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "oxfmt" } }],
			"hard_tabs": true,
			"language_servers": ["!eslint", "!biome", "oxfmt", "..."],
			"prettier": { "allowed": false },
			"tab_size": 4
		},
		"JSON": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": false
			},
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "biome" } }, { "language_server": { "name": "oxfmt" } }],
			"hard_tabs": true,
			"language_servers": ["!eslint", "package-version-server", "biome", "oxfmt", "..."],
			"tab_size": 4
		},
		"JSON5": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": false
			},
			"format_on_save": "on",
			"formatter": { "language_server": { "name": "oxfmt" } },
			"hard_tabs": true,
			"language_servers": ["!eslint", "oxfmt", "..."],
			"tab_size": 4
		},
		"JSONC": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": false
			},
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "biome" } }, { "language_server": { "name": "oxfmt" } }],
			"hard_tabs": true,
			"language_servers": ["!eslint", "biome", "..."],
			"tab_size": 4
		},
		"Markdown": {
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "rumdl" } }],
			"hard_tabs": true,
			"language_servers": ["!marksman", "!markdownlint", "rumdl", "..."],
			"show_whitespaces": "none",
			"tab_size": 4
		},
		"MDX": {
			"format_on_save": "on",
			"formatter": { "language_server": { "name": "oxfmt" } },
			"language_servers": ["!eslint", "oxfmt", "..."],
			"prettier": { "allowed": false }
		},
		"SCSS": {
			"format_on_save": "on",
			"formatter": { "language_server": { "name": "oxfmt" } },
			"language_servers": ["!graphql", "oxfmt", "..."],
			"prettier": { "allowed": false }
		},
		"Shell Script": {
			"format_on_save": "on",
			"formatter": {
				"external": {
					"arguments": ["-i", "4", "-bn", "-ci", "-sr"],
					"command": "shfmt"
				}
			},
			"hard_tabs": true,
			"language_servers": ["bash-language-server", "..."],
			"tab_size": 4
		},
		"TOML": {
			"format_on_save": "on",
			"formatter": "language_server",
			"hard_tabs": true,
			"tab_size": 4
		},
		"TSX": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.fixAll.oxc": true,
				"source.organizeImports.biome": false
			},
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "biome" } }, { "language_server": { "name": "oxfmt" } }],
			"hard_tabs": true,
			"language_servers": [
				"!deno",
				"!eslint",
				"!tailwindcss-language-server",
				"!typescript-language-server",
				"!tsgo", // completely breaks oxlint for some reason.
				"biome",
				"oxfmt",
				"oxlint",
				"vtsls",
				"..."
			],
			"prettier": { "allowed": false },
			"tab_size": 4
		},
		"TypeScript": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.fixAll.oxc": true,
				"source.organizeImports.biome": false
			},
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "biome" } }, { "language_server": { "name": "oxfmt" } }],
			"hard_tabs": true,
			"language_servers": [
				"!deno",
				"!eslint",
				"!tailwindcss-language-server",
				"!typescript-language-server",
				"!tsgo", // completely breaks oxlint for some reason.
				"biome",
				"oxfmt",
				"oxlint",
				"vtsls",
				"..."
			],
			"prettier": { "allowed": false },
			"tab_size": 4
		},
		"YAML": {
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "oxfmt" } }],
			"hard_tabs": false,
			"prettier": { "allowed": false },
			"tab_size": 2
		}
	},
	"lsp": {
		"bash-language-server": {
			"settings": { "bashIde": { "globPattern": "**/*@(.sh|.inc|.bash|.command|.zsh)" } }
		},
		"biome": {
			"settings": {
				"biome": {
					"configurationPath": "./biome.jsonc",
					"rename": true,
					"requireConfiguration": true
				}
			}
		},
		"oxfmt": {
			"initialization_options": {
				"settings": { "configPath": "./.oxfmtrc.json" }
			}
		},
		"oxlint": {
			"initialization_options": {
				"settings": {
					"disableNestedConfig": false,
					"fixKind": "safe_fix",
					"run": "onType",
					"typeAware": true,
					"unusedDisableDirectives": "deny"
				}
			}
		},
		"vtsls": {
			"settings": {
				"javascript": {
					"inlayHints": {
						"enumMemberValues": { "enabled": true },
						"functionLikeReturnTypes": { "enabled": true },
						"parameterNames": {
							"enabled": "none",
							"suppressWhenArgumentMatchesName": false
						},
						"parameterTypes": { "enabled": false },
						"propertyDeclarationTypes": { "enabled": true }
					},
					"updateImportsOnFileMove": { "enabled": "always" }
				},
				"typescript": {
					"inlayHints": {
						"enumMemberValues": { "enabled": true },
						"functionLikeReturnTypes": { "enabled": true },
						"parameterNames": {
							"enabled": "none",
							"suppressWhenArgumentMatchesName": false
						},
						"parameterTypes": { "enabled": false },
						"propertyDeclarationTypes": { "enabled": true }
					},
					"preferences": { "includePackageJsonAutoImports": "on" },
					"updateImportsOnFileMove": { "enabled": "always" }
				}
			}
		}
	},
	"prettier": { "allowed": false },
	"project_name": "Oxlint Plugin Utilities",
	"remove_trailing_whitespace_on_save": true,
	"show_completion_documentation": true,
	"show_completions_on_input": true,
	"show_edit_predictions": true,
	"soft_wrap": "prefer_line",
	"tab_size": 4,
	"terminal": {
		"shell": "system",
		"working_directory": "current_project_directory"
	},
	"use_auto_surround": true,
	"use_autoclose": true,
	"use_on_type_format": true
}
