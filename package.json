{
	"name": "oxlint-plugin-utilities",
	"version": "0.2.2",
	"description": "A smarter wrapper around Oxlint's JS plugins types.",
	"keywords": [
		"lint",
		"linting",
		"oxlint",
		"plugin",
		"rules",
		"utilities"
	],
	"license": "MIT",
	"author": {
		"name": "HowManySmall"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/howmanysmall/oxlint-plugin-utilities.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"module": "src/index.ts",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"biome:check": "biome check",
		"biome:ci": "biome ci",
		"biome:lint": "biome lint",
		"build": "bun run ./scripts/build.ts",
		"commitlint": "commitlint --edit",
		"format": "oxfmt",
		"knip": "knip-bun",
		"lint": "bash -c 'a=$(bash scripts/default-src.sh \"$@\"); bun run oxc $a && bun run biome:check $a' _",
		"oxc": "oxlint",
		"prepare": "lefthook install",
		"prepublishOnly": "bun run build",
		"release": "bumpp",
		"test": "tsd --files 'src/**/*.test-d.ts'",
		"type-check": "tsgo --noEmit"
	},
	"dependencies": {
		"@oxlint/plugins": "^1.59.0",
		"type-fest": "^5.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/types": "^20.5.0",
		"@jsr/cliffy__command": "^1.0.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/bun": "1.3.12",
		"@types/node": "^25.5.2",
		"@typescript/native-preview": "^7.0.0-dev.20260411.1",
		"bumpp": "^11.0.1",
		"changelogithub": "^14.0.0",
		"commitlint": "^20.5.0",
		"consola": "^3.4.2",
		"knip": "^6.4.0",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"oxlint-tsgolint": "^0.20.0",
		"picocolors": "^1.1.1",
		"pretty-bytes": "^7.1.0",
		"pretty-ms": "^9.3.0",
		"temporal-polyfill": "^0.3.2",
		"tsd": "^0.33.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"tsd": {
		"files": [
			"src/**/*.test-d.ts"
		]
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.11"
}
